[
    {
        "position": "bottom",
        "height": 48,
        "spacing": 4,
        "margin-top": 0,
        "margin-bottom": 5,
        "margin-left": 5,
        "margin-right": 5,
        "modules-left": [
            "custom/arch",
            "hyprland/workspaces",
            "wlr/taskbar",
            "hyprland/window"
        ],
        "modules-center": [
            "clock",
            "mpris"
        ],
        "modules-right": [
            "cpu",
            "memory",
            "temperature",
            "pulseaudio",
            "bluetooth",
            "network",
            "tray"
        ],
        "hyprland/workspaces": {
            "format": "{id}",
            "on-scroll-up": "hyprctl dispatch workspace e-1",
            "on-scroll-down": "hyprctl dispatch workspace e+1",
            "persistent-workspaces": {
                "*": [
                    1
                ]
            },
            "anim-color-1": "#00e5ff",
            "anim-color-2": "#b347ff",
            "anim-duration": 3,
            "button-radius": 0,
            "button-pad-v": 0,
            "button-pad-h": 4,
            "button-minw": 35,
            "disable-scroll": true,
            "all-outputs": true,
            "_inverted": false
        },
        "hyprland/window": {
            "format": "{}",
            "max-length": 60,
            "separate-outputs": true,
            "_inverted": false
        },
        "clock": {
            "format": "{:%H:%M | %d}",
            "timezone": "Europe/Lisbon",
            "locale": "pt_PT.utf8",
            "interval": 1,
            "on-click": "flatpak run com.ml4w.calendar",
            "tooltip": true,
            "_inverted": false
        },
        "cpu": {
            "format": "{usage}% ",
            "tooltip": true,
            "interval": 2
        },
        "memory": {
            "format": "{}% ",
            "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
            "interval": 5,
            "_inverted": false
        },
        "temperature": {
            "critical-threshold": 80,
            "format": "{temperatureC}°C {icon}",
            "format-icons": [
                "",
                "",
                ""
            ]
        },
        "network": {
            "format-wifi": "󰤢 {bandwidthDownBits}",
            "format-ethernet": "󰤢 {bandwidthDownBits}",
            "format-disconnected": "󰤠 No Network",
            "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\n↑ {bandwidthUpBits}  ↓ {bandwidthDownBits}",
            "on-click": "nm-connection-editor",
            "interval": 5,
            "_inverted": false
        },
        "bluetooth": {
            "format": "󰂯",
            "format-disabled": "󰂲",
            "format-connected": "󰂱 {device_alias}",
            "on-click": "/usr/bin/blueman-manager",
            "interval": 30,
            "tooltip": true
        },
        "pulseaudio": {
            "format": "{icon} {volume}%",
            "format-muted": " ",
            "format-icons": [
                "",
                "",
                " "
            ],
            "on-click": "pavucontrol",
            "scroll-step": 5,
            "max-volume": 150,
            "format-bluetooth": "{icon} {volume}%",
            "nospacing": 1,
            "_inverted": false
        },
        "wireplumber": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 12'>󰕾</span> {volume}%",
            "format-muted": "<span font='JetBrainsMono Nerd Font Mono 12'>󰝟</span> mute",
            "on-click": "pavucontrol",
            "scroll-step": 5,
            "_inverted": false
        },
        "battery": {
            "format": "{icon} {capacity}%",
            "format-icons": [
                "󰁺",
                "󰁼",
                "󰁾",
                "󰂀",
                "󰂂",
                "󰁹"
            ],
            "format-charging": "󰂄 {capacity}%",
            "format-plugged": "󰚥 {capacity}%",
            "states": {
                "warning": 30,
                "critical": 15
            },
            "_inverted": false
        },
        "idle_inhibitor": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 12'>{icon}</span>",
            "format-icons": {
                "activated": "󰾪",
                "deactivated": "󰾩"
            },
            "_inverted": false
        },
        "mpris": {
            "format": "{player_icon} {title}",
            "format-paused": "{player_icon}  {title}",
            "interval": 1,
            "max-length": 40,
            "_inverted": false
        },
        "privacy": {
            "icon-size": 18,
            "icon-spacing": 4,
            "transition-duration": 250,
            "_inverted": false
        },
        "tray": {
            "spacing": 8,
            "icon-size": 18
        },
        "wlr/taskbar": {
            "format": "{icon}",
            "on-click": "activate",
            "on-click-middle": "close",
            "icon-size": 18,
            "tooltip": true,
            "_inverted": false
        },
        "custom/arch": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 22' color='#ff00ff'>󰣇</span>",
            "on-click": "fuzzel",
            "tooltip": false,
            "arch-icon-glyph": "󰣇",
            "arch-pad-left": 10,
            "arch-pad-right": 15,
            "_inverted": false
        },
        "custom/weather": {
            "format": "{}",
            "exec": "$HOME/.config/waybar/scripts/weather.py",
            "return-type": "json",
            "interval": 3600,
            "tooltip": true,
            "on-click": "flatpak run io.github.amit9838.mousam"
        },
        "custom/updates": {
            "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"󰚰 '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"󰚰 0\",\"class\":\"updated\"}'",
            "return-type": "json",
            "interval": 60,
            "tooltip": false,
            "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
        },
        "custom/swaync": {
            "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
            "format-icons": {
                "none": "󰂚",
                "notification": "󰂜",
                "dnd-none": "󰂛",
                "dnd-notification": "󰂛"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true,
            "tooltip": false
        },
        "custom/power": {
            "format": "⏻",
            "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
            "tooltip": false
        },
        "custom/settings": {
            "format": "󰒓",
            "on-click": "vswaybar-studio",
            "tooltip": false
        },
        "custom/claudebar": {
            "exec": "claudebar --format '{session_bar} {session_pct}% · {session_reset}'",
            "return-type": "json",
            "interval": 30,
            "signal": 13,
            "tooltip": true,
            "on-click": "xdg-open https://claude.ai/settings/usage",
            "_inverted": false
        },
        "custom/bar-cpu": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type cpu",
            "return-type": "json",
            "interval": 2,
            "tooltip": true
        },
        "custom/bar-mem": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type mem",
            "return-type": "json",
            "interval": 5,
            "tooltip": true
        },
        "custom/bar-vol": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type vol",
            "return-type": "json",
            "interval": 2,
            "tooltip": true,
            "on-click": "pavucontrol"
        },
        "custom/bar-wifi": {
            "exec": "$HOME/.config/waybar/scripts/vsbar.py --type wifi",
            "return-type": "json",
            "interval": 5,
            "tooltip": true,
            "on-click": "nm-connection-editor"
        },
        "name": "bar"
    }
]