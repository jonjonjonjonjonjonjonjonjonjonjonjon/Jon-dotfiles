(defwidget clock []
  (box :class "userinfo-parent"
    (label :text time)))


(defwidget powermenu []
  (box :height "200" :width "680" :halign "center" :valign "center" :class "userinfo-parent"
    (box :height "200" :width "226" :halign "center" :valign "center" :class "userinfo-child"
      (button :onclick "systemctl poweroff" :class "poweroff-button"
        (label :class "big-icon-label"  :text "⏻")
      )
    )
    (box :height "200" :width "226" :halign "center" :valign "center" :class "userinfo-child"
      (button :onclick "systemctl reboot" :class "poweroff-button"
        (label :class "big-icon-label"  :text "⟲")
      )
    )
    (box :height "200" :width "226" :halign "center" :valign "center" :class "userinfo-child"
      (button :onclick "~/.config/eww/scripts/power.sh && systemctl sleep"  :class "suspend-button"
        (label :class "big-icon-label"  :text "⏾")
      )
    )
    (box :height "200" :width "226" :halign "center" :valign "center" :class "userinfo-child"
      (button :onclick "command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit"  :class "suspend-button"
        (label :class "big-icon-label"  :text "⏏")
      )
    )
  )
)
