(include "eww_widgets.yuck")

(defwindow main
  :monitor '[0]'
  :stacking "bg"
  :namespace "eww"
  :geometry (geometry
    :x "50px"
    :y "50px"
    :width "100px"
    :height "100px"
    :anchor "bottom right")
  (main))

(defwindow powermenu
  :monitor '[0]'
  :stacking "fg"
  :windowtype "normal"
  :namespace "eww"
  :geometry (geometry 
    :x "0px" 
    :y "0px" 
    :width "400px"   ;; Aumenta a largura para caber o offset
    :height "50px"  ;; Aumenta a altura para caber o offset
    :anchor "center")
  (powermenu))

