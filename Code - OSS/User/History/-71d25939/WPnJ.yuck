(defwindow clock
  :monitor '[0]'
  :stacking "bg"
  :windowtype "normal"
  :namespace "eww"
  :geometry (geometry 
    :x "0px" 
    :y "50px" 
    :width "500px"
    :height "500px"
    :anchor "top center")
  (clock))