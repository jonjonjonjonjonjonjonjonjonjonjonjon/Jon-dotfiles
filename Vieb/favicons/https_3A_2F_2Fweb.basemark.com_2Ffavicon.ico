<script>
let trackingLoaded = false;

function getCookie(name) {
  const value = `; ${document.cookie}`;
  const parts = value.split(`; ${name}=`);
  if (parts.length === 2) return parts.pop().split(";").shift();
}

window.addEventListener("load", function () {
  window.cookieconsent.initialise({
    palette: {
      popup: { background: "#222", text: "#fff" },
      button: { background: "#f1d600", text: "#000" }
    },
    type: "opt-in",
    cookie: {
      expiryDays: 7 // refresh consent weekly
    },
    content: {
      message:
        "On this website we use first or third-party tools that store small files (cookie) on your device. Cookies are normally used to allow the site to run properly (technical cookies), to generate navigation usage reports (statistics cookies) and to suitably advertise our services/products (profiling cookies). We can directly use technical cookies, but you have the right to choose whether or not to enable statistical and profiling cookies. Enabling these cookies, you help us to offer you a better experience.",
      allow: "Enable",
      deny: "Keep disabled",
      link: "Privacy policy",
      href: "https://www.gpuscore.com/privacy-policy/"
    },
    onStatusChange: function (status) {
      if (status === "allow") {
        enableTracking();
      } else if (status === "deny") {
        loadNonPersonalizedAds();
      }
    }
  });

  const consentStatus = getCookie("cookieconsent_status");
  if (consentStatus === "allow") {
    enableTracking();
  } else if (consentStatus === "deny") {
    loadNonPersonalizedAds();
  }
});

function enableTracking() {
  if (trackingLoaded) return;
  trackingLoaded = true;

  // load GA only if consent given
  var gtagScript = document.createElement("script");
  gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=G-XSC9NXTWX2";
  gtagScript.async = true;
  gtagScript.onload = function () {
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    window.gtag = gtag;

    gtag("js", new Date());
    gtag("config", "G-XSC9NXTWX2");
  };
  document.head.appendChild(gtagScript);

  // Google AdSense (personalized)
  var adsense = document.createElement("script");
  adsense.async = true;
  adsense.src =
    "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1345904339052742";
  adsense.setAttribute("crossorigin", "anonymous");
  document.head.appendChild(adsense);
}

function loadNonPersonalizedAds() {
  if (trackingLoaded) return;
  trackingLoaded = true;

  var adsense = document.createElement("script");
  adsense.async = true;
  adsense.src =
    "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1345904339052742";
  adsense.setAttribute("crossorigin", "anonymous");
  document.head.appendChild(adsense);

  // Non-personalized ads
  window.adsbygoogle = window.adsbygoogle || [];
  window.adsbygoogle.push({
    params: { requestNonPersonalizedAds: 1 },
  });
}
</script>
</body>
</html>
